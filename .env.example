# Copy to .env and fill in values before running docker compose up

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_PASSWORD=changeme

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# ── Langfuse (self-hosted setup) ──────────────────────────────────────────────
# LANGFUSE_SALT: any random string (32+ chars)
LANGFUSE_SALT=replace_with_32_or_more_random_chars

# LANGFUSE_ENCRYPTION_KEY: exactly 64 hex characters (256-bit key)
# Generate: openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=replace_with_64_hex_chars_from_openssl_rand_hex_32

# LANGFUSE_NEXTAUTH_SECRET: any random string
LANGFUSE_NEXTAUTH_SECRET=replace_with_random_string

# URL where Langfuse UI is reachable from the browser
LANGFUSE_NEXTAUTH_URL=http://localhost:4000

# ── Langfuse SDK keys (fill after first login to http://localhost:3001) ───────
# Create a project in Langfuse, generate keys under Settings → API Keys
LANGFUSE_SDK_SECRET_KEY=
LANGFUSE_SDK_PUBLIC_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
